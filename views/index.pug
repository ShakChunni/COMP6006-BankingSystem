extends layout

block content
  .row.justify-content-center
    .col-lg-8
      .card.shadow-sm
        .card-body.p-4
          h1.h3.mb-3 Online Banking Website
          p.text-muted.mb-4 A simple banking simulation where you can register, manage accounts, and perform transactions.
          .d-flex.gap-2
            a.btn.btn-primary(href="/register") Register
            a.btn.btn-outline-primary(href="/login") Login
