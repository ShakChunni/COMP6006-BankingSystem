extends ../layout

block content
  .d-flex.justify-content-between.align-items-start.mb-3
    div
      h1.h3.mb-1 Account Details
      p.text-muted.mb-0 Account Number: #{account.accountNumber}
    a.btn.btn-outline-secondary(href="/dashboard") Back to Dashboard

  .row.g-3.mb-4
    .col-md-6
      .card.shadow-sm.h-100
        .card-body
          h2.h5.mb-3 Account Information
          p.mb-2
            strong Type:
            |  #{account.accountType}
          p.mb-2
            strong Status:
            |  #{account.status}
          p.mb-3
            strong Balance:
            |  #{formatCurrency(account.balance)}
          if isOwner
            form(action=`/accounts/${account._id}/toggle-status`, method="POST")
              button.btn.btn-outline-primary(type="submit") #{account.status === "Active" ? "Deactivate" : "Activate"} Account

    .col-md-6
      .card.shadow-sm.h-100
        .card-body
          h2.h5.mb-3 Credit / Debit
          if isOwner
            form(action=`/accounts/${account._id}/transactions`, method="POST")
              .mb-2
                label.form-label(for="type") Transaction Type
                select#type.form-select(name="type", required)
                  option(value="") Select type
                  option(value="credit", selected=(transactionData && transactionData.type === "credit")) Credit
                  option(value="debit", selected=(transactionData && transactionData.type === "debit")) Debit
              .mb-2
                label.form-label(for="amount") Amount
                input#amount.form-control(type="number", name="amount", step="0.01", min="0.01", required, value=(transactionData && transactionData.amount) || "")
              .mb-2
                label.form-label(for="description") Description
                input#description.form-control(type="text", name="description", value=(transactionData && transactionData.description) || "")
              .mb-3
                label.form-label(for="reference") Reference
                input#reference.form-control(type="text", name="reference", value=(transactionData && transactionData.reference) || "")
              button.btn.btn-success(type="submit") Submit Transaction
          else
            .alert.alert-secondary Only account owners can transact.

  .card.shadow-sm.mb-4
    .card-body
      h2.h5.mb-3 Transfer Between Your Accounts
      if isOwner
        if otherAccounts.length
          form(action=`/accounts/${account._id}/transfer`, method="POST")
            input(type="hidden", name="type", value="transfer")
            .row.g-2
              .col-md-4
                label.form-label(for="toAccountId") To Account
                select#toAccountId.form-select(name="toAccountId", required)
                  option(value="") Select destination account
                  each target in otherAccounts
                    option(value=target._id, selected=(transferData && transferData.toAccountId && transferData.toAccountId === String(target._id)))
                      | #{target.accountNumber} (#{target.accountType}) - #{target.status}
              .col-md-2
                label.form-label(for="transferAmount") Amount
                input#transferAmount.form-control(type="number", step="0.01", min="0.01", name="amount", required, value=(transferData && transferData.amount) || "")
              .col-md-3
                label.form-label(for="transferDescription") Description
                input#transferDescription.form-control(type="text", name="description", value=(transferData && transferData.description) || "")
              .col-md-3
                label.form-label(for="transferReference") Reference
                input#transferReference.form-control(type="text", name="reference", value=(transferData && transferData.reference) || "")
            .mt-3
              button.btn.btn-primary(type="submit") Transfer
        else
          .alert.alert-info Create another account first to use transfer.
      else
        .alert.alert-secondary Only account owners can transfer funds.

  .card.shadow-sm
    .card-body
      h2.h5.mb-3 Transaction History
      if transactions.length
        .table-responsive
          table.table.table-sm.table-striped
            thead
              tr
                th Date
                th Type
                th Amount
                th Description
                th Reference
                th Details
            tbody
              each tx in transactions
                tr
                  td= tx.createdAt.toLocaleString()
                  td.text-capitalize= tx.type
                  td= formatCurrency(tx.amount)
                  td= tx.description || "-"
                  td= tx.reference || "-"
                  td
                    if tx.type === "transfer"
                      - const fromCurrent = tx.fromAccount && tx.fromAccount._id.toString() === account._id.toString()
                      if fromCurrent
                        | To #{tx.toAccount ? tx.toAccount.accountNumber : "-"}
                      else
                        | From #{tx.fromAccount ? tx.fromAccount.accountNumber : "-"}
                    else
                      | #{account.accountNumber}
      else
        .alert.alert-info.mb-0 No transactions yet for this account.
