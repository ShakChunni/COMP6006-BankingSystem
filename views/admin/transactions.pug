extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-3
    h1.h3.mb-0 All Transactions
    a.btn.btn-outline-secondary(href="/admin") Back to Admin

  .table-responsive
    table.table.table-striped.table-hover.bg-white
      thead
        tr
          th Date
          th User
          th Type
          th Amount
          th Description
          th Reference
          th Account Details
      tbody
        each tx in transactions
          tr
            td= tx.createdAt.toLocaleString()
            td= tx.createdBy ? tx.createdBy.customerId : "-"
            td.text-capitalize= tx.type
            td= formatCurrency(tx.amount)
            td= tx.description || "-"
            td= tx.reference || "-"
            td
              if tx.type === "transfer"
                | #{tx.fromAccount ? tx.fromAccount.accountNumber : "-"} -> #{tx.toAccount ? tx.toAccount.accountNumber : "-"}
              else
                | #{tx.account ? tx.account.accountNumber : "-"}
